{
  "name": "rensa",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose-development.yaml up --build",
    "dev:all": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @rensa/web dev",
    "dev:notifications": "pnpm --filter @rensa/notifications dev",
    "dev:exif": "pnpm --filter @rensa/exif dev",
    "dev:ai": "pnpm --filter @rensa/ai dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "lefthook": "^2.1.6",
    "typescript": "catalog:",
    "turbo": "latest",
    "ultracite": "^7.3.2"
  }
}
