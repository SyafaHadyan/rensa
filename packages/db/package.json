{
  "name": "@rensa/db",
  "version": "0.0.0",
  "private": true,
  "description": "Rensa's database layer",
  "type": "module",
  "exports": {
    ".": "./src/db.ts",
    "./queries/*": "./queries/*.ts",
    "./schema": "./schemas/index.ts",
    "./schemas/*": "./schemas/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  }
}
